# ─────────────────────────────────────────────────────────────────
#  Second Brain – PDF Insight Surfer
#  .env.example  →  copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────
# Choose ONE: "ollama" | "gemini" | "openai"| "groq"
LLM_PROVIDER=groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local, free, no API key needed) ───────────────────────
# Download from https://ollama.com  then run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Gemini (fast cloud reasoning) ────────────────────────────────
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (optional fallback) ───────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── LlamaParse (optional – only for scanned/complex PDFs) ────────
# Free tier: 1000 pages/day. Get key at https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=YOUR_LLAMA_API_KEY

# ── Embedding Model ───────────────────────────────────────────────
# "local" uses HuggingFace BAAI/bge-small (free, ~130MB download)
# "gemini" uses Google's embedding API (requires GEMINI_API_KEY)
EMBEDDING_PROVIDER=local

# ── Paths ─────────────────────────────────────────────────────────
NOTES_FOLDER=./data/your_notes_folder
CHROMA_DB_PATH=./data/chroma_db
MANIFEST_PATH=./data/manifest.json


# ── Paths ─────────────────────────────────────────────────────────
NOTES_FOLDER=./data/your_notes_folder
CHROMA_DB_PATH=./data/chroma_db
MANIFEST_PATH=./data/manifest.json
